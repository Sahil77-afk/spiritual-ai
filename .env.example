# ── Spiritual AI — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in real values before running.

# Mistral AI API key (required)
API_KEY=your_mistral_api_key_here

# Flask secret key — change to a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Gmail credentials for the contact form (optional — disables mail if empty)
MAIL_USER=your.email@gmail.com
MAIL_PASS=your_gmail_app_password

# Server settings (optional — defaults shown)
PORT=5000
FLASK_DEBUG=false
